# ---- Azure MySQL ----
DB_HOST=mysql-maven.mysql.database.azure.com
DB_PORT=3306
DB_USER=example
DB_PASSWORD=example123
DB_NAME=job-tracker

# Path to Azure SSL root cert (see README for download link)
DB_SSL_CA=DigiCertGlobalRootCA.crt.pem

# ---- Email reminders (SMTP) ----
# Gmail example: use an App Password, NOT your real password.
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=example
SMTP_PASSWORD=example
EMAIL_FROM=example@example.com
EMAIL_TO=example@example.com

# Time of day to send reminders (24h format, local time)
REMINDER_HOUR=9
REMINDER_MINUTE=0

# ---- Flask ----
FLASK_PORT=5000

APP_PASSWORD=example
FLASK_SECRET_KEY=example
