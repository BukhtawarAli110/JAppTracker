# ---- Azure MySQL ----
DB_HOST=mysql-maven.mysql.database.azure.com
DB_PORT=3306
DB_USER=you
DB_PASSWORD=your_password_here
DB_NAME=job-tracker

# Path to Azure SSL root cert (see README for download link)
DB_SSL_CA=DigiCertGlobalRootCA.crt.pem

# ---- Email reminders (SMTP) ----
# Gmail example: use an App Password, NOT your real password.
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=youraddress@gmail.com
EMAIL_TO=youraddress@gmail.com

# Time of day to send reminders (24h format, local time)
REMINDER_HOUR=9
REMINDER_MINUTE=0

# ---- Flask ----
FLASK_PORT=5000

# ---- Auth ----
# The password you'll type to log in
APP_PASSWORD=choose-a-strong-password-here
# Random string used to sign session cookies — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace-with-random-64-char-hex-string
